CREATE TABLE Branch (
    branchid INT PRIMARY KEY,
    branchname VARCHAR(50) DEFAULT 'New Delhi',
    bankid VARCHAR(3),
    FOREIGN KEY (bankid) REFERENCES Bank(bankcode)
);
