select*from studs;
SELECT AVG(physics) AS avg_physics
FROM studs;

SELECT MAX(mathematics) AS highest_marks_maths
FROM studs;

SELECT MIN(chemistry) AS lowest_mark_chemistry
FROM studs;

SELECT COUNT(*) AS pass_physics_count
FROM studs
WHERE physics >= 12;

SELECT *
FROM studs
WHERE physics >= 12
AND chemistry >= 12
AND mathematics >= 25;

SELECT 
    COUNT(*) * 100.0 / (SELECT COUNT(*) FROM studs) 
    AS maths_pass_percentage
FROM studs
WHERE mathematics >= 25;

SELECT 
    COUNT(*) * 100.0 / (SELECT COUNT(*) FROM studs) 
    AS overall_pass_percentage
FROM studs
WHERE physics >= 12
AND chemistry >= 12
AND mathematics >= 25;

SELECT AVG(physics + chemistry + mathematics) AS class_average
FROM studs;

SELECT COUNT(*) AS total_pass_students
FROM studs
WHERE physics >= 12
AND chemistry >= 12
AND mathematics >= 25;
