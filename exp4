CREATE TABLE studs (
    student_id INT PRIMARY KEY,
    name VARCHAR(50),
    physics INT CHECK (physics BETWEEN 0 AND 25),
    chemistry INT CHECK (chemistry BETWEEN 0 AND 25),
    mathematics INT CHECK (mathematics BETWEEN 0 AND 50)
);
